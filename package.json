{
  "name": "ccroute",
  "version": "0.1.0",
  "description": "Simple dynamic routing proxy for Claude Code CLI (Codex + OpenCode Go)",
  "type": "module",
  "private": true,
  "bin": {
    "ccroute": "./ccroute"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile=ccroute",
    "build:all": "bun run scripts/build-all.sh",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "gpt-tokenizer": "^2.5.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
